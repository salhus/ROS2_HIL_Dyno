<?xml version="1.0"?>
<!--
  dyno.urdf.xacro
  ═══════════════════════════════════════════════════════════════════════════════
  URDF/Xacro description for the two-motor WEC HIL Dynamometer.

  Physical layout:
    ┌──────────┐   hydro_joint    ┌──────────┐   pto_joint    ┌──────────┐
    │ base_link ├──────────────── │ hydro_link ├────────────── │ pto_link │
    └──────────┘  (axis0, node 0)  └──────────┘ (axis1, node 1) └──────────┘

  axis0 (hydro_joint):
    - Driven by chrono_wec_simulation_node via hydro_effort_controller.
    - Emulates the hydrodynamic force on the WEC body.
    - Tracks the velocity command from the numerical wave-body model.

  axis1 (pto_joint):
    - Controlled by pto_controller_node via pto_effort_controller.
    - Represents the physical PTO (power take-off) machine.
    - Its measured torque feeds back to the Chrono simulation → HIL loop.

  Both joints share a mechanical shaft. In the ODrive firmware, they are
  connected on the same bus (CAN0) at node_id 0 and 1 respectively.

  ros2_control hardware interface:
    Plugin: odrive_ros2_control_plugin/ODriveHardwareInterface
    Interface: CAN bus (can0), ODrive node IDs 0 and 1.
    See: https://github.com/salhus/hil_odrive_ros2_control

  Xacro parameters (set via xacro:arg or launch file):
    None currently. Geometry is schematic (all inertia values are placeholders).

  References:
    ODrive documentation: https://docs.odriverobotics.com/
    ROS 2 control URDF: https://control.ros.org/jazzy/doc/ros2_control/hardware_interface/doc/hardware_components_userdoc.html
═══════════════════════════════════════════════════════════════════════════════
-->
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="wec_dyno">

  <!-- ═══════════════════════════════════════════════════════════════════════
       Material definitions
  ══════════════════════════════════════════════════════════════════════════ -->
  <material name="dark_grey">
    <color rgba="0.3 0.3 0.3 1.0"/>
  </material>
  <material name="blue">
    <color rgba="0.2 0.4 0.8 1.0"/>
  </material>

  <!-- ═══════════════════════════════════════════════════════════════════════
       Links
  ══════════════════════════════════════════════════════════════════════════ -->

  <!-- base_link: fixed to the test bench frame -->
  <link name="base_link">
    <visual>
      <geometry>
        <box size="0.4 0.2 0.1"/>
      </geometry>
      <material name="dark_grey"/>
    </visual>
    <inertial>
      <mass value="10.0"/>
      <inertia ixx="0.1" ixy="0" ixz="0" iyy="0.1" iyz="0" izz="0.1"/>
    </inertial>
  </link>

  <!-- hydro_link: rotor of Motor 0 (hydro emulator) -->
  <link name="hydro_link">
    <visual>
      <geometry>
        <cylinder radius="0.05" length="0.1"/>
      </geometry>
      <material name="blue"/>
    </visual>
    <inertial>
      <!-- Placeholder inertia. Replace with actual motor rotor inertia. -->
      <mass value="1.0"/>
      <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.002"/>
    </inertial>
  </link>

  <!-- pto_link: rotor of Motor 1 (PTO) -->
  <link name="pto_link">
    <visual>
      <geometry>
        <cylinder radius="0.05" length="0.1"/>
      </geometry>
      <material name="blue"/>
    </visual>
    <inertial>
      <!-- Placeholder inertia. Replace with actual motor rotor inertia. -->
      <mass value="1.0"/>
      <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.002"/>
    </inertial>
  </link>

  <!-- ═══════════════════════════════════════════════════════════════════════
       Joints
  ══════════════════════════════════════════════════════════════════════════ -->

  <!-- hydro_joint: Motor 0 (axis0) — hydro force emulator -->
  <joint name="hydro_joint" type="continuous">
    <parent link="base_link"/>
    <child link="hydro_link"/>
    <origin xyz="0 -0.15 0.05" rpy="0 1.5708 0"/>
    <!-- Rotation axis: X after RPY rotation = shaft axis -->
    <axis xyz="0 0 1"/>
  </joint>

  <!-- pto_joint: Motor 1 (axis1) — PTO machine -->
  <joint name="pto_joint" type="continuous">
    <parent link="hydro_link"/>
    <child link="pto_link"/>
    <origin xyz="0.15 0 0" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>

  <!-- ═══════════════════════════════════════════════════════════════════════
       ros2_control — Hardware interface
  ══════════════════════════════════════════════════════════════════════════ -->

  <ros2_control name="ODriveSystem" type="system">
    <hardware>
      <!--
        ODrive hardware interface plugin.
        Communicates with both ODrive axes over CAN bus (can0).
        Each joint is identified by its ODrive node_id.

        Source: https://github.com/salhus/hil_odrive_ros2_control
      -->
      <plugin>odrive_ros2_control_plugin/ODriveHardwareInterface</plugin>
      <param name="can_interface">can0</param>
    </hardware>

    <!-- Motor 0: hydro emulator (axis0, node_id=0) -->
    <joint name="hydro_joint">
      <param name="node_id">0</param>
      <!-- Effort interface: ros2_control sends torque commands to the ODrive.
           The hydro_effort_controller writes τ_hydro = f(v_ref, v_actual). -->
      <command_interface name="effort">
        <param name="min">-200.0</param>
        <param name="max">200.0</param>
      </command_interface>
      <!-- State interfaces: position, velocity, effort read from ODrive encoder + current. -->
      <state_interface name="position"/>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>

    <!-- Motor 1: PTO machine (axis1, node_id=1) -->
    <joint name="pto_joint">
      <param name="node_id">1</param>
      <!-- Effort interface: pto_controller_node sends τ_pto commands. -->
      <command_interface name="effort">
        <param name="min">-200.0</param>
        <param name="max">200.0</param>
      </command_interface>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
      <!-- Effort state = measured torque = τ_meas → feeds back to Chrono (HIL) -->
      <state_interface name="effort"/>
    </joint>
  </ros2_control>

</robot>
